# Proyecto completo

## "Chatea con tus PDFs": RAG de principio a fin

Un script ejecutable que ingiere un PDF y responde preguntas sobre él. Combina todo lo anterior.

```python
# pip install pypdf chromadb sentence-transformers openai
import chromadb
from pypdf import PdfReader
from sentence_transformers import SentenceTransformer
from langchain_text_splitters import RecursiveCharacterTextSplitter
from openai import OpenAI

# ── 1. Leer el PDF ───────────────────────────────────────────
def leer_pdf(ruta):
    reader = PdfReader(ruta)
    return "\n".join(p.extract_text() for p in reader.pages)

# ── 2. Trocear ───────────────────────────────────────────────
def trocear(texto):
    splitter = RecursiveCharacterTextSplitter(
        chunk_size=500, chunk_overlap=50)
    return splitter.split_text(texto)

# ── 3. Indexar en la vector DB ───────────────────────────────
embed = SentenceTransformer("all-MiniLM-L6-v2")

def indexar(chunks):
    col = chromadb.Client().create_collection("docs")
    col.add(
        documents=chunks,
        embeddings=[embed.encode(c).tolist() for c in chunks],
        ids=[f"c{i}" for i in range(len(chunks))],
    )
    return col

# ── 4. Responder ─────────────────────────────────────────────
client = OpenAI(api_key="sk-...")

def responder(col, pregunta):
    res = col.query(
        query_embeddings=[embed.encode(pregunta).tolist()],
        n_results=3,
    )
    contexto = "\n\n".join(res["documents"][0])
    prompt = (f"Usa SOLO este contexto. Si no está, di 'No lo sé'.\n\n"
              f"Contexto:\n{contexto}\n\nPregunta: {pregunta}")
    r = client.chat.completions.create(
        model="gpt-5.4-mini",
        messages=[{"role": "user", "content": prompt}],
    )
    return r.choices[0].message.content

# ── 5. Ejecutar ──────────────────────────────────────────────
if __name__ == "__main__":
    texto = leer_pdf("mi_documento.pdf")
    col = indexar(trocear(texto))
    while True:
        q = input("\n🧑 Tu pregunta (o 'salir'): ")
        if q.lower() == "salir":
            break
        print("🤖", responder(col, q))
```

Guárdalo como `chat_pdf.py`, pon tu API key, y tendrás un asistente sobre cualquier PDF. **Este es tu primer proyecto real: hazlo funcionar antes de seguir.**

